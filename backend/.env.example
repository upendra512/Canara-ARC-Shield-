# --- Server ---
NODE_ENV=development
PORT=4000

# --- Upload (Layer 0 intake) ---
UPLOAD_MAX_BYTES=26214400

# --- External agent microservices ---
# The backend orchestrates these; it does not do their reasoning. These defaults
# match the nodes started per RUN.md (localhost 8001/8002/8003). COPILOT_URL
# points at Node 1, which serves the /copilot answer endpoint.
NODE1_URL=http://localhost:8001
NODE2_URL=http://localhost:8002
NODE3_URL=http://localhost:8003
COPILOT_URL=http://localhost:8001
# Long enough to cover a cold LLM load on Node 1 (deepseek-r1:8b warmup ~70s).
AGENT_TIMEOUT_MS=180000

# --- Node 1 optional LLM enrichment ---
# Node 1 classifies offline via its taxonomy by default. Set NODE1_LLM_URL to an
# OpenAI-compatible /chat/completions endpoint (e.g. local Ollama, or a hosted
# API with NODE1_LLM_KEY) to refine titles/summaries. Any failure falls back to
# the rule-based result, so the pipeline never blocks on the model.
# These are read by the Node 1 service process, not the backend.
# NODE1_LLM_URL=
# NODE1_LLM_KEY=
# NODE1_LLM_MODEL=gpt-4o-mini
# NODE1_LLM_TIMEOUT=15

# --- Queue ---
# In-process driver is used while REDIS_URL is blank. Set it to activate BullMQ.
REDIS_URL=
QUEUE_CONCURRENCY=2

# --- Cache ---
CACHE_DASHBOARD_TTL_MS=15000

# --- MAP review routing ---
# MAP confidence below this threshold routes to the human review queue.
REVIEW_CONFIDENCE=0.85

# --- Trust layer: Hyperledger Fabric ---
# Leave FABRIC_ENABLED unset/false to use the local hash-chain. Set it to true
# and fill the paths below to record on Fabric. Generate the paths after the
# network is up with: bash fabric/scripts/print-connection.sh
FABRIC_ENABLED=false
FABRIC_CHANNEL=auditchannel
FABRIC_CHAINCODE=audit-ledger
FABRIC_MSP_ID=Org1MSP
FABRIC_PEER_ENDPOINT=localhost:7051
FABRIC_PEER_HOST_ALIAS=peer0.org1.example.com
FABRIC_TLS_CERT_PATH=
FABRIC_CERT_DIR=
FABRIC_KEY_DIR=
