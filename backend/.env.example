# --- Server ---
NODE_ENV=development
PORT=4000

# --- Upload (Layer 0 intake) ---
UPLOAD_MAX_BYTES=26214400

# --- External agent microservices ---
# The backend orchestrates these; it does not do their reasoning. Set each URL
# when the corresponding service is available. The pipeline fails clearly if a
# required node is not configured.
NODE1_URL=
NODE2_URL=
NODE3_URL=
COPILOT_URL=
AGENT_TIMEOUT_MS=20000

# --- Queue ---
# In-process driver is used while REDIS_URL is blank. Set it to activate BullMQ.
REDIS_URL=
QUEUE_CONCURRENCY=2

# --- Cache ---
CACHE_DASHBOARD_TTL_MS=15000

# --- MAP review routing ---
# MAP confidence below this threshold routes to the human review queue.
REVIEW_CONFIDENCE=0.85

# --- Trust layer: Hyperledger Fabric ---
# Leave FABRIC_ENABLED unset/false to use the local hash-chain. Set it to true
# and fill the paths below to record on Fabric. Generate the paths after the
# network is up with: bash fabric/scripts/print-connection.sh
FABRIC_ENABLED=false
FABRIC_CHANNEL=auditchannel
FABRIC_CHAINCODE=audit-ledger
FABRIC_MSP_ID=Org1MSP
FABRIC_PEER_ENDPOINT=localhost:7051
FABRIC_PEER_HOST_ALIAS=peer0.org1.example.com
FABRIC_TLS_CERT_PATH=
FABRIC_CERT_DIR=
FABRIC_KEY_DIR=
